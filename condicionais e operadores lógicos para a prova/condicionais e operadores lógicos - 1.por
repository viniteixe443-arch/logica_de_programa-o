programa {
  funcao inicio() {
    inteiro nota
    escreva("informe a nota do aluno: ")
    leia(nota)

    se(nota >=7){
      escreva("aprovado. ")
    }senao se (nota <7 e nota >= 5){
      escreva("recuperação. ")
    }senao escreva("reprovado")  
    }
}// ler a nota do aluno e fazer a verificação
